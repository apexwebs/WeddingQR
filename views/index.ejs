<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wedding Check-in</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-teal-50 to-teal-100 min-h-screen">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h1 class="text-5xl font-bold text-teal-700 mb-4">💍 Wedding QR Check-in</h1>
      <p class="text-lg text-teal-600">Check in your guests seamlessly</p>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      <a href="/guests.html" class="group">
        <div class="bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow duration-300 border-l-4 border-teal-500">
          <h2 class="text-2xl font-bold text-teal-700 mb-2 group-hover:text-teal-600">Manage Guests</h2>
          <p class="text-gray-600">Add guests and generate QR codes for check-in</p>
        </div>
      </a>
      <a href="/scan.html" class="group">
        <div class="bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow duration-300 border-l-4 border-teal-500">
          <h2 class="text-2xl font-bold text-teal-700 mb-2 group-hover:text-teal-600">Scan QR Code</h2>
          <p class="text-gray-600">Use your phone or tablet to check guests in</p>
        </div>
      </a>
    </div>
  </div>
</body>
</html>