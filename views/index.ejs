<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wedding Guest Check-in</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2 { font-family: 'Playfair Display', serif; }
    .bg-cream { background-color: #fdfbf7; }
    .text-emerald-gold { color: #064e3b; }
    .border-gold { border-color: #d4af37; }
    .bg-gold { background-color: #d4af37; }
    .hover-gold:hover { background-color: #c5a028; }
  </style>
</head>
<body class="bg-cream min-h-screen text-slate-800">
  <div class="max-w-4xl mx-auto px-6 py-20">
    <div class="text-center mb-16">
      <div class="inline-flex items-center justify-center p-3 bg-emerald-50 rounded-full mb-6">
        <i data-lucide="heart" class="w-8 h-8 text-emerald-800 fill-emerald-800/10"></i>
      </div>
      <h1 class="text-5xl md:text-6xl font-bold text-emerald-900 mb-4 italic">The Wedding Gallery</h1>
      <p class="text-xl text-emerald-700/80 font-medium">Guest Management & Seamless Check-in</p>
      <div class="w-24 h-1 bg-gold mx-auto mt-8 rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <a href="/guests.html" class="group relative">
        <div class="bg-white rounded-2xl shadow-sm border border-emerald-100 p-10 h-full transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-gold">
          <div class="flex items-center justify-between mb-6">
            <div class="p-3 bg-emerald-50 rounded-xl group-hover:bg-gold/10 transition-colors">
              <i data-lucide="users" class="w-8 h-8 text-emerald-800"></i>
            </div>
            <i data-lucide="arrow-right" class="w-5 h-5 text-emerald-200 group-hover:text-gold transition-colors"></i>
          </div>
          <h2 class="text-2xl font-bold text-emerald-900 mb-3">Manage Guests</h2>
          <p class="text-slate-600 leading-relaxed">Curate your guest list, send invitations, and generate unique QR codes for every attendee.</p>
        </div>
      </a>

      <a href="/scan.html" class="group relative">
        <div class="bg-white rounded-2xl shadow-sm border border-emerald-100 p-10 h-full transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-gold">
          <div class="flex items-center justify-between mb-6">
            <div class="p-3 bg-emerald-50 rounded-xl group-hover:bg-gold/10 transition-colors">
              <i data-lucide="qr-code" class="w-8 h-8 text-emerald-800"></i>
            </div>
            <i data-lucide="arrow-right" class="w-5 h-5 text-emerald-200 group-hover:text-gold transition-colors"></i>
          </div>
          <h2 class="text-2xl font-bold text-emerald-900 mb-3">Scan QR Code</h2>
          <p class="text-slate-600 leading-relaxed">Provide a smooth entry experience. Use our mobile scanner to check guests in instantly.</p>
        </div>
      </a>
    </div>

    <footer class="mt-20 text-center text-emerald-900/40 text-sm font-medium uppercase tracking-widest">
      &mdash; Forever Begins Today &mdash;
    </footer>
  </div>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>